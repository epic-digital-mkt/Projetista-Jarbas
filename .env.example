# Copie este arquivo para .env e preencha com seus valores reais
# cp .env.example .env

# ─── ClickUp ──────────────────────────────────────────────────────────────────
# Token pessoal: ClickUp > Configurações > Aplicativos > Token de API
CLICKUP_API_KEY=pk_SEU_TOKEN_AQUI

# ID do Workspace: visível na URL — app.clickup.com/{workspace_id}/...
CLICKUP_WORKSPACE=SEU_WORKSPACE_ID

# Seu User ID: ClickUp > Perfil > ID do usuário
CLICKUP_USER_ID=SEU_USER_ID

# ─── Gemini ───────────────────────────────────────────────────────────────────
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=SUA_CHAVE_GEMINI_AQUI

# ─── Saída ────────────────────────────────────────────────────────────────────
# Pasta onde os arquivos Excel serão salvos (opcional)
# OUTPUT_DIR=C:/Users/SeuNome/Downloads/Use Cases
